{
  "name": "workorganizer",
  "private": true,
  "version": "1.0.14",
  "description": "Mooncrew Work Organizer",
  "author": "Mooncrew",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"vite --port 5183 --strictPort\" \"wait-on tcp:5183 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5183 electron .\"",
    "electron:build": "tsc -b && cross-env ELECTRON_BUILD=true vite build --outDir dist-electron-app --base ./ && electron-builder"
  },
  "build": {
    "appId": "app.mooncrew.desktop",
    "productName": "Mooncrew",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "nelkejannis-lab",
      "repo": "flowdo"
    },
    "files": [
      "electron/**/*",
      "dist-electron-app/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons/icon-512.png"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.108.1",
    "@xenova/transformers": "^2.17.2",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.42.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.27.0",
    "sharp": "^0.35.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^9.0.10"
  }
}
